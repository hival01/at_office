# ============================================================
# Environment Configuration
# Copy this file to .env and fill in the values
# ============================================================

# --- Runtime ---
NODE_ENV=development          # development | staging | production
PORT=3000
SITE_URL=http://localhost:3000
LOG_LEVEL=debug               # error | warn | info | debug

# --- Database (Pick ONE based on your ORM choice) ---

# Option A: PostgreSQL with Sequelize
DATABASE_URL=postgres://user:password@localhost:5432/project_guider_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=project_guider_db
DB_USER=user
DB_PASSWORD=password
DB_DIALECT=postgres            # postgres | mysql | sqlite | mariadb

# Option B: MySQL with Sequelize
# DATABASE_URL=mysql://user:password@localhost:3306/project_guider_db
# DB_DIALECT=mysql

# Option C: PostgreSQL/MySQL with Prisma
# DATABASE_URL=postgres://user:password@localhost:5432/project_guider_db

# Option D: MongoDB with Mongoose
# MONGODB_URI=mongodb://localhost:27017/project_guider_db

# --- Authentication (JWT) ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# --- File Upload ---
FILE_STORAGE_DRIVER=local      # local | s3
LOCAL_UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# --- AWS S3 (if FILE_STORAGE_DRIVER=s3) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# --- Email (SMTP) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@projectguider.com

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes
RATE_LIMIT_MAX=100             # max requests per window
