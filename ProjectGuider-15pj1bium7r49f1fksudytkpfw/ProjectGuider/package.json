{
  "name": "project-guider",
  "version": "1.0.0",
  "description": "Production-ready Node.js + Express + TypeScript boilerplate for trainees",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rimraf dist && swc src -d dist && tsc --noEmit && tsc-alias",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo:all",
    "migrate:create": "npx sequelize-cli migration:generate --name",
    "seed": "npx sequelize-cli db:seed:all",
    "seed:undo": "npx sequelize-cli db:seed:undo:all",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio"
  },
  "dependencies": {
    "express": "^4.21.x",
    "cors": "^2.8.x",
    "helmet": "^8.x",
    "hpp": "^0.2.x",
    "compression": "^1.7.x",
    "dotenv": "^16.x",
    "joi": "^17.x",
    "jsonwebtoken": "^9.x",
    "bcryptjs": "^2.4.x",
    "winston": "^3.x",
    "winston-daily-rotate-file": "^5.x",
    "express-rate-limit": "^7.x",
    "multer": "^1.4.x",
    "sequelize": "^6.x",
    "sequelize-typescript": "^2.x",
    "pg": "^8.x",
    "pg-hstore": "^2.x",
    "mysql2": "^3.x",
    "mongoose": "^8.x",
    "swagger-ui-express": "^5.x",
    "socket.io": "^4.x"
  },
  "devDependencies": {
    "typescript": "^5.x",
    "@types/express": "^5.x",
    "@types/node": "^22.x",
    "@types/cors": "^2.8.x",
    "@types/hpp": "^0.2.x",
    "@types/compression": "^1.7.x",
    "@types/jsonwebtoken": "^9.x",
    "@types/bcryptjs": "^2.4.x",
    "@types/multer": "^1.4.x",
    "@types/swagger-ui-express": "^4.x",
    "@swc/cli": "^0.4.x",
    "@swc/core": "^1.x",
    "tsx": "^4.x",
    "rimraf": "^6.x",
    "tsc-alias": "^1.x",
    "sequelize-cli": "^6.x",
    "prisma": "^6.x",
    "@prisma/client": "^6.x",
    "eslint": "^9.x",
    "@typescript-eslint/eslint-plugin": "^8.x",
    "@typescript-eslint/parser": "^8.x",
    "prettier": "^3.x"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
