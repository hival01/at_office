<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Update Applicant</title>
    <link rel="stylesheet" href="/css/style.css" />
    <style>
      .step-fieldset { display: none; }
      .step-fieldset.active { display: block; }
      .step-error { color: #b91c1c; margin: 8px 0; }
    </style>
  </head>
  <body>
    <h1>Update Applicant #<%= applicantId %></h1>
    <p><a href="/applications">Back to list</a></p>
    <% if (formError) { %><p class="step-error"><%= formError %></p><% } %>

    <form id="updateForm" method="POST" action="/applications/<%= applicantId %>/update">
      <fieldset class="step-fieldset active"><legend>Step 1 - Basic</legend>
        <label>First Name</label><input type="text" name="firstName" required value="<%= basic.firstName || '' %>" /><br /><br />
        <label>Last Name</label><input type="text" name="lastName" required value="<%= basic.lastName || '' %>" /><br /><br />
        <label>Email</label><input type="email" name="email" required value="<%= basic.email || '' %>" /><br /><br />
        <label>Phone</label><input type="text" name="phoneNo" required value="<%= basic.phoneNo || '' %>" /><br /><br />
        <label>Designation</label><input type="text" name="designation" required value="<%= basic.designation || '' %>" /><br /><br />
        <div id="genderBlock"></div><br />
        <div id="relationshipBlock"></div>
      </fieldset>

      <fieldset class="step-fieldset"><legend>Step 2 - Address</legend>
        <label>Address 1</label><input type="text" name="address1" required value="<%= basic.address1 || '' %>" /><br /><br />
        <label>Address 2</label><input type="text" name="address2" value="<%= basic.address2 || '' %>" /><br /><br />
        <div id="stateBlock"></div><br />
        <div id="cityBlock"></div><br />
        <label>Zip</label><input type="number" name="zip" required value="<%= basic.zipcode || '' %>" /><br /><br />
        <label>DOB</label><input type="date" name="dob" required value="<%= basic.dob ? new Date(basic.dob).toISOString().slice(0, 10) : '' %>" />
      </fieldset>

      <fieldset class="step-fieldset"><legend>Step 3 - Education</legend>
        <button type="button" id="addEduBtn">Add Row</button>
        <table border="1"><thead><tr><th>Course</th><th>Passing Year</th><th>University</th><th>Result</th><th>Action</th></tr></thead><tbody id="eduBody"></tbody></table>
      </fieldset>

      <fieldset class="step-fieldset"><legend>Step 4 - Work Experience</legend>
        <button type="button" id="addWorkBtn">Add Row</button>
        <table border="1"><thead><tr><th>Company</th><th>From</th><th>To</th><th>Package</th><th>Reason</th><th>Ref No</th><th>Ref Name</th><th>Ref Relation</th><th>Action</th></tr></thead><tbody id="workBody"></tbody></table>
      </fieldset>

      <fieldset class="step-fieldset"><legend>Step 5 - Languages & Technologies</legend>
        <h4>Languages</h4>
        <button type="button" id="addLangBtn">Add Row</button>
        <table border="1"><thead><tr><th>Language</th><th>Read</th><th>Write</th><th>Speak</th><th>Action</th></tr></thead><tbody id="langBody"></tbody></table>
        <h4>Technologies</h4>
        <button type="button" id="addTechBtn">Add Row</button>
        <table border="1"><thead><tr><th>Technology</th><th>Level</th><th>Action</th></tr></thead><tbody id="techBody"></tbody></table>
      </fieldset>

      <fieldset class="step-fieldset"><legend>Step 6 - Preferences</legend>
        <div id="preferredLocation1Block"></div><br />
        <div id="preferredLocation2Block"></div><br />
        <div id="departmentBlock"></div><br />
        <label>Notice Period</label><input type="number" name="noticePeriod" required value="<%= preference ? preference.noticePeriod : '' %>" /><br /><br />
        <label>Expected CTC</label><input type="number" name="expectedCtc" required value="<%= preference ? preference.expectedCTC : '' %>" /><br /><br />
        <label>Current CTC</label><input type="number" name="currentCtc" required value="<%= preference ? preference.currentCTC : '' %>" />
      </fieldset>

      <p id="stepValidationMessage" class="step-error"></p>
      <button type="button" id="prevBtn">Previous</button>
      <button type="button" id="nextBtn">Next</button>
      <button type="submit" id="submitBtn" style="display:none">Submit / Update</button>
    </form>

    <script>
      window.userdata = {
        basic: <%- JSON.stringify(basic) %>,
        preference: <%- JSON.stringify(preference || {}) %>,
        education: <%- JSON.stringify(education || []) %>,
        workExperience: <%- JSON.stringify(workExperience || []) %>,
        languages: <%- JSON.stringify(languages || []) %>,
        technologies: <%- JSON.stringify(technologies || []) %>
      };
    </script>
    <script src="/js/updateForm.js"></script>
  </body>
</html>
