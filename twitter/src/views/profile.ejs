<!DOCTYPE html>
<html>
<head>
    <title><%= user.username %></title>
    <link rel="stylesheet" href="/css/layout.css">
<link rel="stylesheet" href="/css/profile.css">
</head>
<body>

<div class="layout">

    <!-- LEFT SIDEBAR (SAME AS HOME) -->
    <div class="sidebar">
        <h2 class="logo">X</h2>

        <a href="/home">Home</a>
        <a href="/<%= currentUser ? currentUser.username : '#' %>">Profile</a>

        <form action="/logout" method="POST">
            <button class="logout-btn">Logout</button>
        </form>
    </div>

    <!-- CENTER (PROFILE CONTENT) -->
    <div class="feed">

        <!-- HEADER -->
        <div class="feed-header">
            <h2><%= user.username %></h2>
        </div>

        <!-- COVER -->
        <div class="cover">
            <img src="<%= user.cover_page_url || '/images/default-cover.jpg' %>" />
        </div>

        <!-- PROFILE INFO -->
        <div class="profile-header">
            <div class="profile-top">
                <img class="avatar large" src="<%= user.profile_pic_url || '/images/default-avatar.png' %>" />

                <% if (currentUser && currentUser.username.toLowerCase()===user.username.toLowerCase()) { %>
                    <button class="edit-btn" onclick="openModal()">Edit Profile</button>
                    <% } %>
                
                        <% if (currentUser && currentUser.id !==user.id) { %>
                            <button id="followBtn" class="follow-btn <%= isFollowing ? 'following' : '' %>"
                                 onclick="handleFollow(<%= user.id %>)">
                                <%= isFollowing ? 'Following' : 'Follow' %>
                            </button>
                            <% } %>
            </div>

            <h2><%= user.username %></h2>

            <p class="bio">
                <%= user.bio || "No bio available" %>
            </p>

            <p class="join-date">
                Joined <%= new Date(user.created_at).toDateString() %>
            </p>

            <div class="stats">
                <span><b><%= stats.following %></b> Following</span>
                <span><b><%= stats.followers %></b> Followers</span>
                <span><b><%= stats.tweets %></b> Tweets</span>
            </div>
        </div>




        <!-- EDIT MODAL -->
    <div id="editModal" class="modal">
        <div class="modal-content">

            <span class="close" onclick="closeModal()">&times;</span>

            <h2>Edit Profile</h2>

            <form action="/update-profile" method="POST" enctype="multipart/form-data">

                <label>Profile Picture</label>
                <input type="file" name="profile_pic" />

                <label>Cover Photo</label>
                <input type="file" name="cover_pic" />

                <label>Bio</label>
                <textarea name="bio" maxlength="160"><%= user.bio || "" %></textarea>

                <button type="submit" class="save-btn">Save</button>
            </form>

        </div>
    </div>

        <!-- TWEETS (SAME AS HOME UI) -->
        <div class="tweets">

            <% if (tweets.length === 0) { %>
                <p class="no-tweets">No tweets yet</p>
            <% } %>

            <% tweets.forEach(tweet => { %>
                <div class="tweet">

                    <img class="avatar" src="<%= tweet.profile_pic_url || '/images/default-avatar.png' %>" />

                    <div class="tweet-content">
                        <a href="/<%= tweet.username %>">
                            <b><%= tweet.username %></b>
                        </a>

                        <p><%= tweet.content %></p>

                        <% if (tweet.image_url) { %>
                            <div class="tweet-image-container">
                                <img class="tweet-img" src="<%= tweet.image_url %>" />
                            </div>
                        <% } %>

                        <small><%= new Date(tweet.created_at).toLocaleString() %></small>
                    </div>
                </div>
            <% }) %>

        </div>

    </div>

    <!-- RIGHT BAR -->
    <div class="rightbar">
        <h3>Trends</h3>
        <p>Coming soon...</p>
    </div>

</div>

<script>
function openModal() {
    document.getElementById("editModal").style.display = "flex";
}
function closeModal() {
    document.getElementById("editModal").style.display = "none";
}

async function handleFollow(userId) {
    const btn = document.getElementById("followBtn");

    const res = await fetch("/follow", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify({ followingId: userId })
    });

    const data = await res.json();

    if (data.success) {
        if (data.following) {
            btn.innerText = "Following";
            btn.classList.add("following");
        } else {
            btn.innerText = "Follow";
            btn.classList.remove("following");
        }
    }
}

</script>

</body>
</html>

