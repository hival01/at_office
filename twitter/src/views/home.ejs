<!DOCTYPE html>
<html>
<head>
    <title>Home</title>
    <link rel="stylesheet" href="/css/layout.css">
<link rel="stylesheet" href="/css/home.css">
</head>
<body>

<div class="layout">

    <!-- LEFT SIDEBAR -->
    <div class="sidebar">
        <h2 class="logo">X</h2>

        <a href="/home">Home</a>
        
         <a href="/<%= currentUser ? currentUser.username : '#' %>">Profile</a>

        <form action="/logout" method="POST">
            <button class="logout-btn">Logout</button>
        </form>
    </div>

    <!-- MAIN FEED -->
    <div class="feed">

        <!-- HEADER -->
        <div class="feed-header">
            <h2>Home</h2>
        </div>

        <!-- TWEET BOX -->
        <div class="tweet-box">

            <img src="<%= currentUser ? currentUser.profile_pic_url : '/images/default-avatar.png' %>" />

            <form action="/tweet" method="POST" enctype="multipart/form-data">
                <textarea name="content" placeholder="What is happening?" required></textarea>

                <input type="file" name="image" accept="image/*" />

                <button type="submit">Post</button>
            </form>

        </div>

        <!-- TWEETS LIST -->
        <div class="tweets">

            <% if (tweets.length === 0) { %>
                <p class="no-tweets">No tweets yet</p>
            <% } %>

            <% tweets.forEach(tweet => { %>
                <div class="tweet">

                    <img class="avatar" src="<%= tweet.profile_pic_url %>" />

                    <div class="tweet-content">
                        <a href="/<%= tweet.username %>">
                            <b><%= tweet.username %></b>
                        </a>

                        <p><%= tweet.content %></p>

                        <% if (tweet.image_url) { %>
                            <div class="tweet-image-container">
                                <img class="tweet-img" src="<%= tweet.image_url %>" />
                            </div>
                        <% } %> 
                        
                        
                        <small>
                            <%= new Date(tweet.created_at).toLocaleString() %>
                        </small>


                        <!-- ACTION BAR -->
                    <div class="tweet-actions">
                    
                        <!-- COMMENT -->
                        <span class="action comment" onclick="toggleComments(<%= tweet.tweet_id %>)">
                            <i class="fa-regular fa-comment">💬</i>
                            <span><%= tweet.comment_count || 0 %></span>
                        </span>
                    
                        <!-- RETWEET -->
                        <span class="action retweet">
                            🔁 <span>0</span>
                        </span>
                    
                        <!-- LIKE -->
                         <span 
                            class="action like <%= tweet.is_liked == 1 ? 'liked' : '' %>" 
                            onclick="handleLike(this, <%= tweet.tweet_id %>)"
                        >
                            <svg class="like-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M16.697 5.5c-1.222-.06-2.679.351-3.827 1.36-1.148-1.009-2.604-1.42-3.827-1.36C6.729 5.647 4.5 8.193 4.5 10.961c0 3.311 1.469 5.434 3.024 7.247 1.574 1.836 3.764 3.534 4.39 4.025.077.06.155.09.233.09.078 0 .155-.03.232-.09.626-.491 2.817-2.189 4.391-4.025 1.556-1.813 3.025-3.936 3.025-7.247 0-2.768-2.229-5.314-4.542-5.461z" />
                            </svg>

                            

                            <span class="like-count"><%= tweet.like_count || 0 %></span>

                        </span>
                    
                    </div>

                    <div id="comments-<%= tweet.tweet_id %>" class="comments-section" style="display:none;">
                        
                        <div class="comment-list"></div>

                        <form onsubmit="postComment(event, <%= tweet.tweet_id %>)">
                            <input type="text" name="content" placeholder="Post your reply..." required />
                            <button type="submit">Reply</button>
                        </form>

                    </div>


                    </div>

                </div>
            <% }) %>

        </div>

    </div>

    <!-- RIGHT SIDEBAR -->
    <div class="rightbar">
        <h3>Trends</h3>
        <p>Coming soon...</p>
    </div>

</div>




<script>
async function handleLike(element, tweetId) {
    try {
        const res = await fetch("/like", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({ tweetId })
        });

        const data = await res.json();

        if (data.success) {
            const countEl = element.querySelector(".like-count");

            // update count
            countEl.innerText = data.likeCount;

            // toggle UI
            
            element.classList.toggle("liked", data.liked);
        }

    } catch (err) {
        console.error("Like error:", err);
    }
}


//logic for comment
async function toggleComments(tweetId) {
    const container = document.getElementById(`comments-${tweetId}`);

    if (container.style.display === "none") {
        container.style.display = "block";

        const res = await fetch(`/comments/${tweetId}`);
        const data = await res.json();

        const list = container.querySelector(".comment-list");
        list.innerHTML = renderComments(data.comments);

    } else {
        container.style.display = "none";
    }
}

function renderComments(comments, level = 0) {
    let html = "";

    comments.forEach(c => {
        html += `
            <div class="comment" style="margin-left: ${level * 20}px">
                <img src="${c.profile_pic_url}" />
                <div class="comment-body">
                    <b>${c.username}</b>
                    <p>${c.content}</p>

                    <span class="reply-btn" onclick="showReplyBox(${c.comment_id})">
                        Reply
                    </span>

                    <div id="reply-box-${c.comment_id}" class="reply-box" style="display:none;">
                        <input 
                            type="text" 
                            placeholder="Reply..." 
                            onkeypress="handleReply(event, ${c.comment_id}, ${c.tweet_id})"
                        />
                    </div>
                </div>
            </div>
        `;

        if (c.replies && c.replies.length > 0) {
            html += renderComments(c.replies, level + 1);
        }
    });

    return html;
}



async function postComment(e, tweetId) {
    e.preventDefault();

    const input = e.target.querySelector("input");
    const content = input.value;

    const res = await fetch("/comment", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify({
            tweetId,
            content
        })
    });

    const data = await res.json();

    if (data.success) {
        input.value = "";
        toggleComments(tweetId); // refresh
        toggleComments(tweetId);
    }
}


function showReplyBox(commentId) {
    const box = document.getElementById(`reply-box-${commentId}`);
    box.style.display = box.style.display === "none" ? "block" : "none";
}



async function handleReply(e, parentCommentId, tweetId) {
    if (e.key === "Enter") {
        const content = e.target.value;

        const res = await fetch("/comment", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                tweetId,
                content,
                parentCommentId
            })
        });

        const data = await res.json();

        if (data.success) {
            toggleComments(tweetId);
            toggleComments(tweetId);
        }
    }
}

</script>


</body>
</html>